{
  "name": "paykitjs",
  "version": "0.0.4",
  "description": "TypeScript-first payments orchestration framework for modern SaaS",
  "keywords": [
    "creem",
    "orchestration",
    "paddle",
    "payments",
    "paypal",
    "polar",
    "stripe",
    "subscriptions",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getpaykit/paykit.git"
  },
  "bin": {
    "paykitjs": "./src/cli/index.ts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "paykit-source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./handlers/next": {
      "paykit-source": "./src/handlers/next.ts",
      "types": "./src/handlers/next.ts",
      "default": "./src/handlers/next.ts"
    },
    "./client": {
      "paykit-source": "./src/client/index.ts",
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./database": {
      "paykit-source": "./src/database/schema.ts",
      "types": "./src/database/schema.ts",
      "default": "./src/database/schema.ts"
    }
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "typecheck": "tsc --build",
    "db:generate": "drizzle-kit generate --config src/database/drizzle.config.ts"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.21",
    "@types/pg": "^8.18.0",
    "@clack/prompts": "^1.1.0",
    "better-call": "^2.0.2",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "jiti": "^2.6.1",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.28.8",
    "typescript": "^5.9.2",
    "yocto-spinner": "^0.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.5",
    "tsdown": "^0.21.1",
    "vitest": "^4.0.18"
  }
}
